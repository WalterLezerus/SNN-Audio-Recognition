   "source": [
    "# SNN Audio Recognition — Colab Training\n",
    "Spiking CNN trained on Google Speech Commands v0.02 (35 words).  \n",
    "**Runtime: GPU (T4 recommended)** — Runtime > Change runtime type > T4 GPU"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Install dependencies\n",
    "!pip install snntorch soundfile --quiet"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os, urllib.request, tarfile\n",
    "from pathlib import Path\n",
    "\n",
    "import soundfile as sf\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "import torchaudio.transforms as T\n",
    "from torch.utils.data import DataLoader\n",
    "from torch.optim import Adam\n",
    "from torch.optim.lr_scheduler import StepLR\n",
    "from datetime import datetime\n",
    "\n",
    "import snntorch as snn\n",
    "from snntorch import surrogate\n",
    "\n",
    "device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n",
    "print(f'Device: {device}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Dataset ───────────────────────────────────────────────────────────────────\n",
    "\n",
    "DATA_DIR     = '/content/data'\n",
    "DATASET_URL  = 'http://download.tensorflow.org/data/speech_commands_v0.02.tar.gz'\n",
    "SAMPLE_RATE  = 16000\n",
    "N_MELS       = 40\n",
    "N_FFT        = 512\n",
    "HOP_LENGTH   = 160\n",
    "\n",
    "CLASSES = sorted([\n",
    "    'backward', 'bed', 'bird', 'cat', 'dog', 'down', 'eight', 'five',\n",
    "    'follow', 'forward', 'four', 'go', 'happy', 'house', 'learn', 'left',\n",
    "    'marvin', 'nine', 'no', 'off', 'on', 'one', 'right', 'seven', 'sheila',\n",
    "    'six', 'stop', 'three', 'tree', 'two', 'up', 'visual', 'wow', 'yes', 'zero'\n",
    "])\n",
    "CLASS_TO_IDX = {c: i for i, c in enumerate(CLASSES)}\n",
    "NUM_CLASSES  = len(CLASSES)\n",
    "\n",
    "\n",
    "def _download(data_dir):\n",
    "    extract_dir = Path(data_dir) / 'SpeechCommands'\n",
    "    dataset_dir = extract_dir / 'speech_commands_v0.02'\n",
    "    if dataset_dir.exists():\n",
    "        return dataset_dir\n",
    "    tar_path = Path(data_dir) / 'speech_commands_v0.02.tar.gz'\n",
    "    os.makedirs(data_dir, exist_ok=True)\n",
    "    if not tar_path.exists():\n",
    "        print('Downloading Speech Commands v0.02 (~2.4GB)...')\n",
    "        urllib.request.urlretrieve(DATASET_URL, tar_path)\n",
    "        print('Download complete.')\n",
    "    print('Extracting...')\n",
    "    extract_dir.mkdir(parents=True, exist_ok=True)\n",
    "    with tarfile.open(tar_path) as tf:\n",
    "        tf.extractall(extract_dir)\n",
    "    print('Extraction complete.')\n",
    "    return dataset_dir\n",
    "\n",
    "\n",
    "def _get_samples(dataset_dir, subset):\n",
    "    dataset_dir = Path(dataset_dir)\n",
    "    val_set  = set((dataset_dir / 'validation_list.txt').read_text().splitlines())\n",
    "    test_set = set((dataset_dir / 'testing_list.txt').read_text().splitlines())\n",
    "    samples = []\n",
    "    for label in CLASSES:\n",
    "        label_dir = dataset_dir / label\n",
    "        if not label_dir.exists():\n",
    "            continue\n",
    "        for wav_file in sorted(label_dir.glob('*.wav')):\n",
    "            rel = f'{label}/{wav_file.name}'\n",
    "            if subset == 'validation':\n",
    "                if rel in val_set:  samples.append((str(wav_file), label))\n",
    "            elif subset == 'testing':\n",
    "                if rel in test_set: samples.append((str(wav_file), label))\n",
    "            else:\n",
    "                if rel not in val_set and rel not in test_set:\n",
    "                    samples.append((str(wav_file), label))\n",
    "    return samples\n",
    "\n",
    "\n",
    "def rate_encode(mel_spec, n_steps):\n",
    "    mel_expanded = mel_spec.unsqueeze(0).expand(n_steps, -1, -1, -1)\n",
    "    return torch.bernoulli(mel_expanded)\n",
    "\n",
    "\n",
    "class SpeechCommandsDataset(torch.utils.data.Dataset):\n",
    "    def __init__(self, subset, n_time_steps=50, data_dir=DATA_DIR):\n",
    "        self.n_time_steps   = n_time_steps\n",
    "        self.mel_transform  = T.MelSpectrogram(sample_rate=SAMPLE_RATE, n_fft=N_FFT,\n",
    "                                                hop_length=HOP_LENGTH, n_mels=N_MELS)\n",
    "        self.amplitude_to_db = T.AmplitudeToDB()\n",
    "        dataset_dir = _download(data_dir)\n",
    "        self.samples = _get_samples(dataset_dir, subset)\n",
    "        print(f'[{subset}] {len(self.samples)} samples loaded.')\n",
    "\n",
    "    def __len__(self):\n",
    "        return len(self.samples)\n",
    "\n",
    "    def __getitem__(self, idx):\n",
    "        wav_path, label = self.samples[idx]\n",
    "        audio, _ = sf.read(wav_path, dtype='float32')\n",
    "        waveform = torch.from_numpy(audio).unsqueeze(0)\n",
    "        n = waveform.shape[1]\n",
    "        if n < SAMPLE_RATE:\n",
    "            waveform = torch.nn.functional.pad(waveform, (0, SAMPLE_RATE - n))\n",
    "        else:\n",
    "            waveform = waveform[:, :SAMPLE_RATE]\n",
    "        mel = self.amplitude_to_db(self.mel_transform(waveform))\n",
    "        mel_min, mel_max = mel.min(), mel.max()\n",
    "        mel = (mel - mel_min) / (mel_max - mel_min) if mel_max > mel_min else torch.zeros_like(mel)\n",
    "        return rate_encode(mel, self.n_time_steps), CLASS_TO_IDX[label]\n",
    "\n",
    "\n",
    "def collate_fn(batch):\n",
    "    spikes, labels = zip(*batch)\n",
    "    spikes = torch.stack(spikes).permute(1, 0, 2, 3, 4)\n",
    "    return spikes, torch.tensor(labels, dtype=torch.long)\n",
    "\n",
    "\n",
    "def get_dataloaders(batch_size=64, n_time_steps=50):\n",
    "    train_ds = SpeechCommandsDataset('training',   n_time_steps)\n",
    "    val_ds   = SpeechCommandsDataset('validation', n_time_steps)\n",
    "    train_loader = DataLoader(train_ds, batch_size=batch_size, shuffle=True,\n",
    "                              num_workers=2, pin_memory=True, collate_fn=collate_fn)\n",
    "    val_loader   = DataLoader(val_ds,   batch_size=batch_size, shuffle=False,\n",
    "                              num_workers=2, pin_memory=True, collate_fn=collate_fn)\n",
    "    return train_loader, val_loader"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Model ─────────────────────────────────────────────────────────────────────\n",
    "\n",
    "SLOPE = 25\n",
    "\n",
    "class SNNAudioNet(nn.Module):\n",
    "    def __init__(self, num_classes=35, beta=0.9):\n",
    "        super().__init__()\n",
    "        spike_grad = surrogate.fast_sigmoid(slope=SLOPE)\n",
    "\n",
    "        self.conv1 = nn.Conv2d(1, 16, kernel_size=3, padding=1)\n",
    "        self.lif1  = snn.Leaky(beta=beta, spike_grad=spike_grad)\n",
    "        self.pool1 = nn.AvgPool2d(2)\n",
    "\n",
    "        self.conv2 = nn.Conv2d(16, 32, kernel_size=3, padding=1)\n",
    "        self.lif2  = snn.Leaky(beta=beta, spike_grad=spike_grad)\n",
    "        self.pool2 = nn.AvgPool2d(2)\n",
    "\n",
    "        self.conv3 = nn.Conv2d(32, 64, kernel_size=3, padding=1)\n",
    "        self.lif3  = snn.Leaky(beta=beta, spike_grad=spike_grad)\n",
    "        self.pool3 = nn.AvgPool2d(2)\n",
    "\n",
    "        self.gap    = nn.AdaptiveAvgPool2d(1)\n",
    "        self.fc1    = nn.Linear(64, 128)\n",
    "        self.lif4   = snn.Leaky(beta=beta, spike_grad=spike_grad)\n",
    "        self.fc_out = nn.Linear(128, num_classes)\n",
    "\n",
    "    def forward(self, x):\n",
    "        time_steps = x.shape[0]\n",
    "        mem1 = self.lif1.init_leaky()\n",
    "        mem2 = self.lif2.init_leaky()\n",
    "        mem3 = self.lif3.init_leaky()\n",
    "        mem4 = self.lif4.init_leaky()\n",
    "        mem_out_accum = None\n",
    "        for t in range(time_steps):\n",
    "            frame = x[t]\n",
    "            out = self.pool1(self.conv1(frame))\n",
    "            spk1, mem1 = self.lif1(out, mem1)\n",
    "            out = self.pool2(self.conv2(spk1))\n",
    "            spk2, mem2 = self.lif2(out, mem2)\n",
    "            out = self.pool3(self.conv3(spk2))\n",
    "            spk3, mem3 = self.lif3(out, mem3)\n",
    "            out = self.gap(spk3).flatten(1)\n",
    "            out = self.fc1(out)\n",
    "            spk4, mem4 = self.lif4(out, mem4)\n",
    "            logits = self.fc_out(spk4)\n",
    "            mem_out_accum = logits if mem_out_accum is None else mem_out_accum + logits\n",
    "        return mem_out_accum"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Training ──────────────────────────────────────────────────────────────────\n",
    "\n",
    "EPOCHS       = 30\n",
    "BATCH_SIZE   = 64   # larger batch on GPU\n",
    "LR           = 1e-3\n",
    "N_TIME_STEPS = 50\n",
    "\n",
    "train_loader, val_loader = get_dataloaders(batch_size=BATCH_SIZE, n_time_steps=N_TIME_STEPS)\n",
    "\n",
    "model     = SNNAudioNet(num_classes=NUM_CLASSES).to(device)\n",
    "optimizer = Adam(model.parameters(), lr=LR)\n",
    "scheduler = StepLR(optimizer, step_size=10, gamma=0.5)\n",
    "loss_fn   = nn.CrossEntropyLoss()\n",
    "\n",
    "print(f'Training on: {device}')\n",
    "print(f'Classes: {NUM_CLASSES}  |  Time steps: {N_TIME_STEPS}  |  Batch: {BATCH_SIZE}')\n",
    "\n",
    "best_acc = 0.0\n",
    "\n",
    "for epoch in range(1, EPOCHS + 1):\n",
    "    model.train()\n",
    "    total_loss, correct, total = 0.0, 0, 0\n",
    "\n",
    "    for data, targets in train_loader:\n",
    "        data, targets = data.float().to(device), targets.to(device)\n",
    "        optimizer.zero_grad()\n",
    "        logits = model(data)\n",
    "        loss   = loss_fn(logits, targets)\n",
    "        loss.backward()\n",
    "        optimizer.step()\n",
    "        total_loss += loss.item()\n",
    "        correct    += (logits.argmax(1) == targets).sum().item()\n",
    "        total      += targets.size(0)\n",
    "\n",
    "    # Validation\n",
    "    model.eval()\n",
    "    val_correct, val_total = 0, 0\n",
    "    with torch.no_grad():\n",
    "        for data, targets in val_loader:\n",
    "            data, targets = data.float().to(device), targets.to(device)\n",
    "            preds = model(data).argmax(1)\n",
    "            val_correct += (preds == targets).sum().item()\n",
    "            val_total   += targets.size(0)\n",
    "\n",
    "    train_acc = correct / total\n",
    "    val_acc   = val_correct / val_total\n",
    "    scheduler.step()\n",
    "\n",
    "    print(f'Epoch {epoch:>3}/{EPOCHS} | Loss: {total_loss/len(train_loader):.4f} | '\n",
    "          f'Train acc: {train_acc:.3f} | Val acc: {val_acc:.3f}')\n",
    "\n",
    "    if val_acc > best_acc:\n",
    "        best_acc = val_acc\n",
    "        torch.save(model.state_dict(), '/content/best.pth')\n",
    "        print(f'  Saved checkpoint (val acc: {best_acc:.3f})')\n",
    "\n",
    "print(f'\\nDone. Best val acc: {best_acc:.3f}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
